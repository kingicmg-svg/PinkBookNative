{
  "expo": {
    "name": "PinkBook",
    "slug": "pinkbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pinkbook",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pinkbook.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Access to camera for photo capture and booking uploads",
        "NSPhotoLibraryUsageDescription": "Access to photo library for booking media",
        "NSLocalNetworkUsageDescription": "Access local network for development",
        "LSApplicationQueriesSchemes": ["itms-apps"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "{{ EXPO_PUBLIC_EAS_PROJECT_ID }}"
      }
    },
    "owner": "pinkbook-team",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/{{ EXPO_PUBLIC_EAS_PROJECT_ID }}",
      "enabled": true,
      "checkOnLaunch": "always",
      "fallbackToCacheTimeout": 0
    }
  }
}
