{
  "expo": {
    "name": "PinkBook",
    "slug": "pinkbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pinkbook",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pinkbook.app",
      "buildNumber": "1"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access needed"
        }
      ]
    ],
    "android": {
      "package": "com.pinkbook.app"
    }
  }
}
