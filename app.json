{
  "expo": {
    "name": "PinkBook",
    "slug": "pinkbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pinkbook",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pinkbook.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "PinkBook uses Face ID so you can sign in securely without typing your password."
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access needed"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PinkBook needs access to your photo library to upload portfolio and before/after images."
        }
      ],
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "android": {
      "package": "com.pinkbook.app"
    }
  }
}
